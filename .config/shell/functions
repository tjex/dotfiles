# search .scripts folder and executer
scripts() {
	if result=($(fd . -tf -Earchived ${HOME}/.local/scripts | fzf)); then
		$result
	else
		return
	fi
}

tref() {
	if result=($(fd . ${HOME}/dev/tref | fzf --preview='bat --color=always --style=numbers {}')); then
		nvim $result
	else
		return
	fi
}

trefg() {
	local search=$1
	rg -i -w $search ${HOME}/dev/tref
}

