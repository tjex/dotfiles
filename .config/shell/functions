# Use lf to switch directories and bind it to ctrl-o
lfcd() {
	local tmp="$(mktemp -uq)"
	trap 'rm -f $tmp >/dev/null 2>&1 && trap - HUP INT QUIT TERM PWR EXIT' HUP INT QUIT TERM PWR EXIT
	lf -last-dir-path="$tmp" "$@"
	if [ -f "$tmp" ]; then
		dir="$(cat "$tmp")"
		[ -d "$dir" ] && [ "$dir" != "$(pwd)" ] && cd "$dir"
	fi
}

# play a folder of files with mpv
mpvd() {
	folder=$(fd . --type d | fzf --preview 'tree -C {} | head -200')
    mpv $folder
}


# mv a folder into a folder that you make, in the same command.
mvmk() {
	mkdir -p -- "$argv[-1]"
	mv "$@"
}

# use fzf to search for dirs and return them inplace in the current prompt
fzf_dir(){
    LBUFFER="${LBUFFER}$(fd . --type d | fzf --preview 'tree -C {} | head -200')"
    ret=$?
    zle reset-prompt
    return $ret
}
# export the directory as a widget to use in keybinds
zle -N fzf_dir 

