# vim: filetype=bash
#
# Use lf to switch directories and bind it to ctrl-o
lfcd() {
	tmp="$(mktemp -uq)"
	trap 'rm -f $tmp >/dev/null 2>&1 && trap - HUP INT QUIT TERM PWR EXIT' HUP INT QUIT TERM PWR EXIT
	lf -last-dir-path="$tmp" "$@"
	if [ -f "$tmp" ]; then
		dir="$(cat "$tmp")"
		[ -d "$dir" ] && [ "$dir" != "$(pwd)" ] && cd "$dir"
	fi
}

# play a folder of files with mpv
mpvf() {
	mpv $(find . -type d -print | fzf --preview 'tree -C {} | head -200')
}

# mv a folder into a folder that you make, in the same command.
mvmk() {
	mkdir -p -- "$argv[-1]"
	mv "$@"
}

