# vim: filetype=bash

yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

yabai -m config \
    debug_output on \
    layout bsp \
    top_padding    10 \
    bottom_padding 10 \
    left_padding   10 \
    right_padding  10 \
    window_gap     10 \
    window_shadow off \
    auto_balance off \
    split_ratio 0.5


yabai -m config \
    window_opacity on \
    active_window_opacity 0.85 \
    normal_window_opacity 0.85

# rules
# manage=off together with grid, places a custom window size on a custom grid.
# units measured in 'tiles' - i.e. divisions of the screen resultant from (rows * cols).
# grid=<rows>:<cols>:<start-x>:<start-y>:<width>:<height>

# things that get launched regularly
yabai -m rule --add app="^Raycast$" title="Raycast Settings" manage=off 
yabai -m rule --add app="^Dictionary$" manage=off opacity=1.0 grid=3:3:1:1:1:1
yabai -m rule --add app="^System Settings$" manage=off sticky=on opacity=1.0
yabai -m rule --add app="^WezTerm$" title="^lf$" manage=off opacity=0.9 grid=5:5:2:1:1:2
yabai -m rule --add app="^WezTerm$" title="^gopass$" manage=off opacity=0.9 grid=3:3:1:1:1:1
yabai -m rule --add app="^WezTerm$" title="^bkmr$" manage=off opacity=0.9 grid=5:3:1:2:1:1 

# general apps that I don't want any tiling with
yabai -m rule --add app="^Max$" manage=off
yabai -m rule --add app="^Carbon Copy Cloner$" manage=off 

