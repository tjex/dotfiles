# vim: filetype=bash

yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

yabai -m config \
    debug_output on \
    layout bsp \
    top_padding    10 \
    bottom_padding 10 \
    left_padding   10 \
    right_padding  10 \
    window_gap     10 \
    window_shadow off \
    auto_balance off \
    split_ratio 0.5


yabai -m config \
    window_opacity on \
    active_window_opacity 0.8 \
    normal_window_opacity 0.8

# rules
# manage=off together with grid, places a custom window size on a custom grid.
# units measured in 'tiles' - i.e. divisions of the screen resultant from (rows * cols).
# grid=<rows>:<cols>:<start-x>:<start-y>:<width>:<height>

# floating window presets
# cb9 = occupy the center-bottom, in a grid of 9
cc9="manage=off grid=3:3:1:1:1:1"
cb9="manage=off grid=3:3:1:2:1:1"
cl9="manage=off grid=3:3:2:2:1:1"

# things that get launched regularly
# yabai -m rule --add app="^WezTerm$" opacity=1.0
yabai -m rule --add app="^Raycast$" title="Raycast Settings" manage=off 
yabai -m rule --add app="^System Settings$" manage=off sticky=on opacity=1.0
yabai -m rule --add app="^WezTerm$" title="^lf$" ${cc9}
yabai -m rule --add app="^Dictionary$" ${cc9}
yabai -m rule --add app="^WezTerm$" title="^gopass$" opacity=1.0 sticky=on ${cc9}
yabai -m rule --add app="^WezTerm$" title="^bkmr$" opacity=1.0 sticky=on ${cc9} 
yabai -m rule --add app="^WezTerm$" title="^nvim$" opacity=1.0 sticky=on ${cc9} 
yabai -m rule --add app="^WezTerm$" title="^qalc$" opacity=1.0 sticky=on ${cb9} 
yabai -m rule --add app="^Todoist$" title[!]="^- Todoist$" manage=off

# general apps that I don't want any tiling with
yabai -m rule --add app="^Max$" manage=off
yabai -m rule --add app="^Carbon Copy Cloner$" manage=off 
